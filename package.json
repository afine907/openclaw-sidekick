{
  "name": "openclaw-sidekick",
  "version": "0.2.0",
  "type": "module",
  "description": "OpenClaw AI Assistant in browser sidebar",
  "main": "src/background.js",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:run && npm run test:e2e",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/**/*.{js,html,css}",
    "format:check": "prettier --check src/**/*.{js,html,css}",
    "build": "node build.cjs"
  },
  "keywords": [
    "chrome-extension",
    "openclaw",
    "ai-assistant",
    "sidebar"
  ],
  "author": "OpenClaw Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^8.0.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "prettier": "^3.0.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "vitest": {
    "testEnvironment": "jsdom",
    "include": [
      "tests/**/*.test.js"
    ],
    "coverage": {
      "provider": "v8",
      "reporter": [
        "text",
        "json",
        "html"
      ],
      "include": [
        "src/**/*.js"
      ],
      "exclude": [
        "**/node_modules/**",
        "**/tests/**"
      ]
    }
  }
}
